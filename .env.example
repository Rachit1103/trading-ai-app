# Trading AI App Configuration

# Groww App Credentials (optional - for automated login)
GROWW_USERNAME=your_username
GROWW_PASSWORD=your_password

# Telegram Bot Token (optional - for notifications)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Trading Settings
RISK_LEVEL=medium
TIMEFRAME=1d
MAX_POSITIONS=5

# API Keys (if using external data sources)
ALPHA_VANTAGE_API_KEY=your_api_key
